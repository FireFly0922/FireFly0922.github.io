# 复制本文件为 .env，填入真实密钥。.env 已在 .gitignore，绝不会被提交或 push。
# 用法：daily-agent -llm real   （程序启动时自动读取 .env）
#
# 二选一：

# —— 方式 A：官方 Anthropic ——
# ANTHROPIC_API_KEY=sk-ant-在这里粘贴你的key

# —— 方式 B：第三方 Anthropic 兼容网关（如 DeepSeek）——
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=sk-在这里粘贴你的token
# ANTHROPIC_MODEL=deepseek-v4-pro[1m]
