{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "removeComments": false,
    "noEmitOnError": true,
    "rootDir": ".",
    "outDir": "../internal/server/web"
  },
  "comment": "本地勾选页：effects.js + app.js 输出到 internal/server/web（Go 内嵌）。",
  "include": ["effects.ts", "app.ts"]
}
