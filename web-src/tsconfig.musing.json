{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "removeComments": false,
    "noEmitOnError": true,
    "rootDir": ".",
    "outDir": "../site"
  },
  "comment": "随笔阅读页：effects.js + musing.js 输出到 site/。",
  "include": ["effects.ts", "musing.ts"]
}
