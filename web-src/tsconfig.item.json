{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "removeComments": false,
    "noEmitOnError": true,
    "rootDir": ".",
    "outDir": "../site"
  },
  "comment": "单项详情页：effects.js + item.js 输出到 site/。与 site/day 分开编译。",
  "include": ["effects.ts", "item.ts"]
}
